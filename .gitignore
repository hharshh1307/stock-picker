# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/

# Data & logs
# Note: stock_picker.db is tracked for deployment (see git lfs or direct commit)
data/*.db-shm
data/*.db-wal
logs/*.log
*.log

# Environment - NEVER commit these
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Lock files (optional, can be large)
uv.lock

# Secrets
*.pem
*.key
credentials*.json

# Frontend (web/)
web/node_modules/
web/.next/
web/.env.local
