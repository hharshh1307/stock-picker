# Gemini AI (required for agent, signals, embeddings)
GEMINI_API_KEY=your-gemini-api-key

# Groww integration (optional)
GROWW_TOKEN=your-groww-token
GROWW_API_SECRET=your-groww-secret

# Admin API token (must match frontend NEXT_PUBLIC_ADMIN_TOKEN)
ADMIN_API_TOKEN=niftysage-admin-2025

# Frontend URL for CORS (set after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app

# Data directory (Railway: /data, local: ./data)
# DATA_DIR=/data
